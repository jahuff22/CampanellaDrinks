{
  "functions": {
    "api/index.js": {
      "includeFiles": "{index.html,style.css,style-lounge.css,script.js,drinks.js,questions.js,landing/**,business/**,shared/**}"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/r/:restaurant/t/:table",
      "destination": "/api"
    },
    {
      "source": "/r/:restaurant",
      "destination": "/api"
    },
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/:path*",
      "destination": "/api"
    }
  ]
}
