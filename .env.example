OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-5.4-nano
AI_MONTHLY_LIMIT_DOLLARS=5
AI_HARD_MONTHLY_CAP_DOLLARS=6

# Pricing defaults are used by the local monthly budget guard.
# Update these if you choose a different model.
AI_INPUT_PRICE_PER_1M=0.2
AI_CACHED_INPUT_PRICE_PER_1M=0.02
AI_OUTPUT_PRICE_PER_1M=1.25

# Optional extra budget reservation before each call.
AI_RESERVED_CALL_COST_DOLLARS=0

# Optional production storage target for recommendation events.
RECOMMENDATION_EVENTS_WEBHOOK_URL=

# Optional production read target for restaurant dashboards.
# If blank, the webhook URL is used for reads too.
RECOMMENDATION_EVENTS_READ_URL=
